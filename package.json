{
	"name": "lemons-search",
	"version": "0.5.1",
	"description": "A blazingly fast fuzzy finder with file preview.",
	"main": "main.js",
	"scripts": {
		"dev": "vite build --mode=development --watch",
		"build": "bun run typecheck && vite build --mode=production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "bun test",
		"test:log": "LOG_TESTS=true bun test",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint --max-warnings=0 packages/obsidian/** --no-warn-ignored",
		"lint:fix": "eslint --max-warnings=0 --fix packages/obsidian/** --no-warn-ignored",
		"check": "bun run wasm:fmt:check && bun run wasm:test && bun run wasm:build && bun run format:check && bun run tsc && bun run lint && bun run test",
		"check:fix": "bun run wasm:fmt && bun run wasm:test && bun run wasm:build && bun run format && bun run tsc && bun run lint:fix && bun run test",
		"release": "lemons-helpers release",
		"stats": "bun run automation/stats.ts",
		"wasm:build": "cd packages/lemons-search && wasm-pack build --target web",
		"wasm:dev": "cd packages/lemons-search && wasm-pack build --dev --target web",
		"wasm:profile": "cd packages/lemons-search && wasm-pack build --profiling --target web",
		"wasm:fmt": "cd packages/lemons-search && cargo fmt",
		"wasm:fmt:check": "cd packages/lemons-search && cargo fmt --check",
		"wasm:lint": "cd packages/lemons-search && cargo clippy",
		"wasm:test": "cd packages/lemons-search && wasm-pack test --node"
	},
	"keywords": [],
	"author": "Moritz Jung",
	"license": "GPL-3.0",
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@happy-dom/global-registrator": "^20.9.0",
		"@lemons_dev/parsinom": "^0.1.0",
		"@types/bun": "^1.3.12",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-isaacscript": "^4.0.0",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"eslint-plugin-only-warn": "^1.2.1",
		"eslint-plugin-svelte": "^3.17.0",
		"lemons-obsidian-plugin-helpers": "https://github.com/mProjectsCode/lemons-obsidian-plugin-helpers",
		"obsidian": "latest",
		"obsidian-typings": "^5.20.0",
		"prettier": "^3.8.3",
		"string-argv": "^0.3.2",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svelte-preprocess": "^6.0.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.8",
		"vite-plugin-banner": "^0.8.1",
		"vite-plugin-static-copy": "^4.1.0"
	},
	"dependencies": {}
}
