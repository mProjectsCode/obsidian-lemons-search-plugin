{
	"name": "lemons-search",
	"version": "0.5.6",
	"description": "A blazingly fast fuzzy finder with file preview.",
	"main": "main.js",
	"scripts": {
		"dev": "vite build --mode=development --watch",
		"build": "bun run typecheck && bun run wasm:build && vite build --mode=production",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "bun test",
		"test:log": "LOG_TESTS=true bun test",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint --max-warnings=0 packages/obsidian/** --no-warn-ignored",
		"lint:fix": "eslint --max-warnings=0 --fix packages/obsidian/** --no-warn-ignored",
		"check": "bun run wasm:fmt:check && bun run wasm:test && bun run wasm:build && bun run format:check && bun run typecheck && bun run lint && bun run test",
		"check:fix": "bun run wasm:fmt && bun run wasm:test && bun run wasm:build && bun run format && bun run typecheck && bun run lint:fix && bun run test",
		"release": "lemons-automation release",
		"wasm:build": "cd packages/lemons-search && wasm-pack build --target web",
		"wasm:dev": "cd packages/lemons-search && wasm-pack build --dev --target web",
		"wasm:profile": "cd packages/lemons-search && wasm-pack build --profiling --target web",
		"wasm:fmt": "cd packages/lemons-search && cargo fmt",
		"wasm:fmt:check": "cd packages/lemons-search && cargo fmt --check",
		"wasm:lint": "cd packages/lemons-search && cargo clippy",
		"wasm:test": "cd packages/lemons-search && wasm-pack test --node",
		"wasm:bench": "cd packages/lemons-search && CARGO_TARGET_WASM32_UNKNOWN_UNKNOWN_RUNNER=wasm-bindgen-test-runner cargo bench --target wasm32-unknown-unknown",
		"postinstall": "bun run wasm:build"
	},
	"keywords": [],
	"author": "Moritz Jung",
	"license": "GPL-3.0",
	"devDependencies": {
		"@happy-dom/global-registrator": "^20.9.0",
		"@lemons_dev/lemons-obsidian-plugin-automation": "^0.1.3",
		"@lemons_dev/parsinom": "^0.2.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"eslint": "^9.39.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"eslint-plugin-only-warn": "^1.2.1",
		"eslint-plugin-svelte": "^3.19.0",
		"obsidian": "latest",
		"obsidian-typings": "^6.13.0",
		"prettier": "^3.8.3",
		"svelte": "^5.56.0",
		"svelte-check": "^4.4.8",
		"svelte-preprocess": "^6.0.5",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^8.0.14",
		"vite-plugin-banner": "^0.8.1",
		"vite-plugin-static-copy": "^4.1.0"
	},
	"dependencies": {}
}
